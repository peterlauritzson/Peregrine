<?xml version="1.0" encoding="utf-8"?>
<Catalog>

    <!-- =====================================================================
         PEREGRINE: IN-ZONE VALIDATOR
         Returns true when the target unit currently has the PeregrineInZone
         marker behavior (count > 0).  Used by any system that needs to
         confirm a unit is inside an active zone structure's radius.
    ===================================================================== -->
    <CValidatorUnitCompareBehaviorCount id="PeregrineIsInZone">
        <WhichUnit Value="Caster"/>
        <Behavior value="PeregrineInZone"/>
        <Compare value="GT"/>
        <Value value="0"/>
    </CValidatorUnitCompareBehaviorCount>

    <!-- =====================================================================
         PEREGRINE: TERRAN AUTO-TRAIN VALIDATOR
         Fires the SCV train effect only when the caster (CC/OC/PF) has
         fewer than 16 workers nearby.  WorkerCount is the native field
         that also drives the worker-count tooltip above Command Centers.
    ===================================================================== -->
    <CValidatorUnitCompareField id="PeregrineAutoTrain_WorkerBelowSat">
        <WhichUnit Value="Caster"/>
        <Field value="WorkerCount"/>
        <Compare value="LT"/>
        <Value value="16"/>
    </CValidatorUnitCompareField>

</Catalog>
