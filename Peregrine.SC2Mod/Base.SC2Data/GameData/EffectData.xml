<?xml version="1.0" encoding="utf-8"?>
<Catalog>

    <!-- =====================================================================
         SHARED: Apply PeregrineInZone marker to a target unit.
         Reused by every advantage aura's effect set.
    ===================================================================== -->
    <CEffectApplyBehavior id="PeregrineApplyInZone">
        <Behavior value="PeregrineInZone"/>
    </CEffectApplyBehavior>

    <!-- =====================================================================
         1: FERAL RECLAMATION (Zerg)
         Heals allied non-structure units for 2 HP every 0.5s (= 4 HP/sec)
         while inside the zone. Regen applied directly; no stat buff.
         CEffectModifyUnit VitalArray Change = absolute HP healed per call.
    ===================================================================== -->
    <CEffectModifyUnit id="PeregrineRegen_FeralReclamation">
        <VitalArray index="Life">
            <Change value="2"/>
        </VitalArray>
    </CEffectModifyUnit>

    <CEffectSet id="PeregrineAuraSet_FeralReclamation">
        <EffectArray value="PeregrineApplyInZone"/>
        <EffectArray value="PeregrineRegen_FeralReclamation"/>
    </CEffectSet>

    <CEffectEnumArea id="PeregrineAuraEffect_FeralReclamation">
        <!-- Include all non-structure, non-missile, alive, visible allied units -->
        <SearchFilters value="-;Enemy,Neutral,Structure,Missile,Dead,Hidden"/>
        <AreaArray Radius="8" Effect="PeregrineAuraSet_FeralReclamation"/>
    </CEffectEnumArea>

    <!-- =====================================================================
         2: HYPER-METABOLIC OVERHEAL (Zerg)
         +100 max HP via buff + heals 3 HP every 0.5s (= 6 HP/sec) in zone.
    ===================================================================== -->
    <CEffectApplyBehavior id="PeregrineApplyBuff_HyperMetabolicOverheal">
        <Behavior value="PeregrineAdvBuff_HyperMetabolicOverheal"/>
    </CEffectApplyBehavior>

    <CEffectModifyUnit id="PeregrineRegen_HyperMetabolicOverheal">
        <VitalArray index="Life">
            <Change value="3"/>
        </VitalArray>
    </CEffectModifyUnit>

    <CEffectSet id="PeregrineAuraSet_HyperMetabolicOverheal">
        <EffectArray value="PeregrineApplyInZone"/>
        <EffectArray value="PeregrineApplyBuff_HyperMetabolicOverheal"/>
        <EffectArray value="PeregrineRegen_HyperMetabolicOverheal"/>
    </CEffectSet>

    <CEffectEnumArea id="PeregrineAuraEffect_HyperMetabolicOverheal">
        <SearchFilters value="-;Enemy,Neutral,Structure,Missile,Dead,Hidden"/>
        <AreaArray Radius="8" Effect="PeregrineAuraSet_HyperMetabolicOverheal"/>
    </CEffectEnumArea>

