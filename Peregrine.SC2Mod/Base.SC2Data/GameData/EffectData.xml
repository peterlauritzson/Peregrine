    <!-- =====================================================================
         7: ORBITAL MUNITIONS (Terran)
         Zone structure fires two effects every 1s:
           (a) Applies PeregrineInZone to allied non-structure units in range.
           (b) Deals 20 damage to enemy non-structure units in range.
         OrbitalMunitions has no stat buff — its power IS the enemy damage.
    ===================================================================== -->

    <!-- (a) Ally search for InZone marker -->
    <CEffectEnumArea id="PeregrineAllyAura_OrbitalMunitions">
        <SearchFilters value="-;Enemy,Neutral,Structure,Missile,Dead,Hidden"/>
        <AreaArray Radius="8" Effect="PeregrineApplyInZone"/>
    </CEffectEnumArea>

    <!-- (b) Enemy search for strike damage -->
    <CEffectDamage id="PeregrineOrbitalStrike">
        <Amount value="20"/>
    </CEffectDamage>

    <CEffectEnumArea id="PeregrineEnemyStrike_OrbitalMunitions">
        <!-- Exclude caster's Player, Ally, Neutral — targets enemies only -->
        <SearchFilters value="-;Player,Ally,Neutral,Structure,Missile,Dead,Hidden"/>
        <AreaArray Radius="8" Effect="PeregrineOrbitalStrike"/>
    </CEffectEnumArea>

    <!-- Combined set fired by the zone aura behavior -->
    <CEffectSet id="PeregrineAuraSet_OrbitalMunitions">
        <EffectArray value="PeregrineAllyAura_OrbitalMunitions"/>
        <EffectArray value="PeregrineEnemyStrike_OrbitalMunitions"/>
    </CEffectSet>

