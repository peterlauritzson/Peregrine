<?xml version="1.0" encoding="utf-8"?>
<Catalog>

    <!-- =====================================================================
         PEREGRINE: IN-ZONE MARKER
         Applied to allied units inside a zone structure's aura radius.
         Duration 0.75s is slightly longer than the aura Period of 0.5s,
         so it stays refreshed while inside the zone and expires quickly
         when a unit leaves (or the structure is destroyed).
    ===================================================================== -->
    <CBehaviorBuff id="PeregrineInZone">
        <InfoFlags index="Hidden" value="1"/>
        <Alignment value="Positive"/>
        <Duration value="0.75"/>
        <MaxStackCount value="1"/>
    </CBehaviorBuff>

    <!-- =====================================================================
         ZONE AURA BEHAVIORS
         Added dynamically to zone structures by ZoneAdvantage.galaxy based
         on the owning player's drafted advantage. Permanent on the structure.
         Period 0.5s → fires PeriodicEffect which searches allies in 8-radius.
    ===================================================================== -->

    <!-- 1: Feral Reclamation (Zerg) — periodic HP heal to allies in zone -->
    <CBehaviorBuff id="PeregrineAura_FeralReclamation">
        <InfoFlags index="Hidden" value="1"/>
        <BehaviorFlags index="Permanent" value="1"/>
        <Period value="0.5"/>
        <PeriodicEffect value="PeregrineAuraEffect_FeralReclamation"/>
    </CBehaviorBuff>

    <!-- 2: Hyper-Metabolic Overheal (Zerg) — +100 max HP + fast regen -->
    <CBehaviorBuff id="PeregrineAura_HyperMetabolicOverheal">
        <InfoFlags index="Hidden" value="1"/>
        <BehaviorFlags index="Permanent" value="1"/>
        <Period value="0.5"/>
        <PeriodicEffect value="PeregrineAuraEffect_HyperMetabolicOverheal"/>
    </CBehaviorBuff>

    <!-- 3: Adaptive Camouflage (Zerg) — +3 life armor in zone -->
    <CBehaviorBuff id="PeregrineAura_AdaptiveCamouflage">
        <InfoFlags index="Hidden" value="1"/>
        <BehaviorFlags index="Permanent" value="1"/>
        <Period value="0.5"/>
        <PeriodicEffect value="PeregrineAuraEffect_AdaptiveCamouflage"/>
    </CBehaviorBuff>

    <!-- 4: Quantum Relocation (Protoss) — +30% move speed in zone -->
    <CBehaviorBuff id="PeregrineAura_QuantumRelocation">
        <InfoFlags index="Hidden" value="1"/>
        <BehaviorFlags index="Permanent" value="1"/>
        <Period value="0.5"/>
        <PeriodicEffect value="PeregrineAuraEffect_QuantumRelocation"/>
    </CBehaviorBuff>

    <!-- 5: Harmonic Shielding (Protoss) — +4 shield armor in zone -->
    <CBehaviorBuff id="PeregrineAura_HarmonicShielding">
        <InfoFlags index="Hidden" value="1"/>
        <BehaviorFlags index="Permanent" value="1"/>
        <Period value="0.5"/>
        <PeriodicEffect value="PeregrineAuraEffect_HarmonicShielding"/>
    </CBehaviorBuff>

    <!-- 6: Chronological Override (Protoss) — +40% attack speed, +20% move speed -->
    <CBehaviorBuff id="PeregrineAura_ChronologicalOverride">
        <InfoFlags index="Hidden" value="1"/>
        <BehaviorFlags index="Permanent" value="1"/>
        <Period value="0.5"/>
        <PeriodicEffect value="PeregrineAuraEffect_ChronologicalOverride"/>
    </CBehaviorBuff>

    <!-- 7: Orbital Munitions (Terran) — auto-damages enemies every 1s -->
    <CBehaviorBuff id="PeregrineAura_OrbitalMunitions">
        <InfoFlags index="Hidden" value="1"/>
        <BehaviorFlags index="Permanent" value="1"/>
        <Period value="1.0"/>
        <PeriodicEffect value="PeregrineAuraSet_OrbitalMunitions"/>
    </CBehaviorBuff>

    <!-- 8: Kinetic Overdrive (Terran) — +25% move speed in zone -->
    <CBehaviorBuff id="PeregrineAura_KineticOverdrive">
        <InfoFlags index="Hidden" value="1"/>
        <BehaviorFlags index="Permanent" value="1"/>
        <Period value="0.5"/>
        <PeriodicEffect value="PeregrineAuraEffect_KineticOverdrive"/>
    </CBehaviorBuff>

    <!-- 9: Scrap Scavenging (Terran) — +2 life armor in zone (simplified) -->
    <CBehaviorBuff id="PeregrineAura_ScrapScavenging">
        <InfoFlags index="Hidden" value="1"/>
        <BehaviorFlags index="Permanent" value="1"/>
        <Period value="0.5"/>
        <PeriodicEffect value="PeregrineAuraEffect_ScrapScavenging"/>
    </CBehaviorBuff>

    <!-- 10: Phase Shifting (Wildcard) — +20% move speed, +1 all armor in zone -->
    <CBehaviorBuff id="PeregrineAura_PhaseShifting">
        <InfoFlags index="Hidden" value="1"/>
        <BehaviorFlags index="Permanent" value="1"/>
        <Period value="0.5"/>
        <PeriodicEffect value="PeregrineAuraEffect_PhaseShifting"/>
    </CBehaviorBuff>

    <!-- =====================================================================
         PEREGRINE: TERRAN AUTO-TRAIN SCV
         Applied permanently to CommandCenter / OrbitalCommand / PlanetaryFortress.
         Every 8 seconds it fires a PeriodicEffect that issues Train_SCV on the
         caster, but only when PeregrineAutoTrain_WorkerBelowSat passes
         (native WorkerCount field < 16).  Minerals are deducted normally.
    ===================================================================== -->
    <CBehaviorBuff id="PeregrineAutoTrain_SCV">
        <InfoFlags index="Hidden" value="1"/>
        <BehaviorFlags index="Permanent" value="1"/>
        <Period value="8.0"/>
        <PeriodicEffect value="PeregrineAutoTrain_SCVEffect"/>
    </CBehaviorBuff>

    <!-- =====================================================================
         ADVANTAGE UNIT BUFFS
         Applied to non-structure allies inside the zone radius.
         Duration 0.75s + MaxStackCount 1 = refreshes while in zone,
         expires ~0.25s after leaving (next period won't fire).
    ===================================================================== -->

    <!-- 1: Feral Reclamation — regen applied via CEffectModifyUnit, no stat buff -->

    <!-- 2: Hyper-Metabolic Overheal — +100 max HP -->
    <CBehaviorBuff id="PeregrineAdvBuff_HyperMetabolicOverheal">
        <Alignment value="Positive"/>
        <Duration value="0.75"/>
        <MaxStackCount value="1"/>
        <Modification>
            <VitalMaxArray index="Life" value="100"/>
        </Modification>
    </CBehaviorBuff>

    <!-- 3: Adaptive Camouflage — +3 life armor -->
    <CBehaviorBuff id="PeregrineAdvBuff_AdaptiveCamouflage">
        <Alignment value="Positive"/>
        <Duration value="0.75"/>
        <MaxStackCount value="1"/>
        <Modification>
            <LifeArmorBonus value="3"/>
        </Modification>
    </CBehaviorBuff>

    <!-- 4: Quantum Relocation — +30% move speed -->
    <CBehaviorBuff id="PeregrineAdvBuff_QuantumRelocation">
        <Alignment value="Positive"/>
        <Duration value="0.75"/>
        <MaxStackCount value="1"/>
        <Modification MoveSpeedMultiplier="1.3"/>
    </CBehaviorBuff>

    <!-- 5: Harmonic Shielding — +4 shield armor -->
    <CBehaviorBuff id="PeregrineAdvBuff_HarmonicShielding">
        <Alignment value="Positive"/>
        <Duration value="0.75"/>
        <MaxStackCount value="1"/>
        <Modification ShieldArmorBonus="4"/>
    </CBehaviorBuff>

    <!-- 6: Chronological Override — +40% attack speed, +20% move speed -->
    <CBehaviorBuff id="PeregrineAdvBuff_ChronologicalOverride">
        <Alignment value="Positive"/>
        <Duration value="0.75"/>
        <MaxStackCount value="1"/>
        <Modification AttackSpeedMultiplier="1.4" MoveSpeedMultiplier="1.2"/>
    </CBehaviorBuff>

    <!-- 7: Orbital Munitions — damage applied to enemies directly (no unit buff) -->

    <!-- 8: Kinetic Overdrive — +25% move speed -->
    <CBehaviorBuff id="PeregrineAdvBuff_KineticOverdrive">
        <Alignment value="Positive"/>
        <Duration value="0.75"/>
        <MaxStackCount value="1"/>
        <Modification MoveSpeedMultiplier="1.25"/>
    </CBehaviorBuff>

    <!-- 9: Scrap Scavenging — +2 life armor (simplified) -->
    <CBehaviorBuff id="PeregrineAdvBuff_ScrapScavenging">
        <Alignment value="Positive"/>
        <Duration value="0.75"/>
        <MaxStackCount value="1"/>
        <Modification>
            <LifeArmorBonus value="2"/>
        </Modification>
    </CBehaviorBuff>

    <!-- 10: Phase Shifting — +20% move speed, +1 life armor, +1 shield armor -->
    <CBehaviorBuff id="PeregrineAdvBuff_PhaseShifting">
        <Alignment value="Positive"/>
        <Duration value="0.75"/>
        <MaxStackCount value="1"/>
        <Modification MoveSpeedMultiplier="1.2" ShieldArmorBonus="1">
            <LifeArmorBonus value="1"/>
        </Modification>
    </CBehaviorBuff>

    <!-- =====================================================================
         PEREGRINE: ZERG COLONY CONNECTIVITY MARKERS
         Refreshed by ZergEconomy.galaxy once per connectivity pulse.
         Duration 1.2s > pulse 1.0s so valid states stay latched between pulses.
    ===================================================================== -->
    <CBehaviorBuff id="PeregrineCreepNode_Connected">
        <InfoFlags index="Hidden" value="1"/>
        <Alignment value="Positive"/>
        <Duration value="1.2"/>
        <MaxStackCount value="1"/>
