    <CBehaviorBuff id="PeregrineCreepNode_Disconnected">
        <InfoFlags index="Hidden" value="1"/>
        <Alignment value="Negative"/>
        <Duration value="1.2"/>
        <MaxStackCount value="1"/>
    </CBehaviorBuff>

