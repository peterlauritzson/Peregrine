<?xml version="1.0" encoding="utf-8"?>
<Catalog>
    <CUnit id="Adept">
        <LifeStart value="100"/>
        <LifeMax value="100"/>
    </CUnit>

    <!-- =====================================================================
         PEREGRINE: GHOST BUILDER
         One spawned per Terran player at game start (off-map, ~(-200, -200)).
         Invisible, invulnerable, no collision, no selection.
         Holds PeregrineGhostBuild_Refinery with Range 500 so Galaxy can
         issue build orders targeting any geyser on the map.
    ===================================================================== -->
    <CUnit id="PeregrineGhostBuilder">
        <EditorCategories value="ObjectFamily:Peregrine"/>
        <FlagArray index="Unselectable" value="1"/>
        <FlagArray index="Untargetable" value="1"/>
        <FlagArray index="Invulnerable" value="1"/>
        <FlagArray index="NoScore" value="1"/>
        <LifeArmor value="99"/>
        <ShieldArmor value="99"/>
        <DeathRevealRadius value="0"/>
        <AbilArray Link="PeregrineGhostBuild_Refinery"/>
    </CUnit>

    <!-- Resource Highway: static pipeline node.
         parent=CreepTumorBurrowed — minimal Zerg structure.
         Aliases cleared so the unit shows its own name.
         Both inherited abilities removed by index.
         makeCreep4x4 swapped for makeCreep8x6 for bare-terrain creep generation. -->
    <CUnit id="PeregrineResourceHighway" parent="CreepTumorBurrowed">
        <EditorCategories value="ObjectFamily:Peregrine"/>
        <FlagArray index="NoScore" value="1"/>
        <FlagArray index="Cloaked" value="0"/>
        <FlagArray index="Buried" value="0"/>
        <!-- Clear name aliases so the unit shows "Resource Highway" not "Creep Tumor" -->
        <LeaderAlias value=""/>
        <SelectAlias value=""/>
        <TechAliasArray index="0" removed="1"/>
        <!-- Remove both inherited abilities by index -->
        <AbilArray index="0" removed="1"/>
        <AbilArray index="1" removed="1"/>
        <!-- Swap creep behavior for bare-terrain scale -->
        <BehaviorArray Link="makeCreep4x4" removed="1"/>
        <BehaviorArray Link="makeCreep8x6"/>
        <!-- Empty card -->
        <CardLayouts/>
        <Footprint value="Footprint2x2Contour"/>
        <PlacementFootprint value="Footprint2x2"/>
        <Radius value="1"/>
        <SeparationRadius value="1"/>
        <InnerRadius value="0.5"/>
        <MinimapRadius value="0.75"/>
        <LifeStart value="450"/>
        <LifeMax value="450"/>
        <LifeArmor value="1"/>
    </CUnit>

</Catalog>
