<?xml version="1.0" encoding="utf-8"?>
<Catalog>
    <!-- Resource Highway actor: uses CreepTumor model directly, scaled 2.5x on birth.
         parent="GenericUnitStandard" gives standard UnitBirth/UnitDeath/selection binding.
         CreepTumor model id is defined in liberty.sc2mod ModelData.xml. -->
    <CActorUnit id="PeregrineResourceHighway" parent="GenericUnitStandard" unitName="PeregrineResourceHighway">
        <Model value="CreepTumor"/>
        <On Terms="UnitBirth" Send="SetScale 2.500000"/>
    </CActorUnit>
</Catalog>
